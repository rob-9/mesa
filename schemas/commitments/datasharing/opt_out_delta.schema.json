{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mesa.dev/schemas/commitments/datasharing/opt_out_delta.schema.json",
  "title": "Opt-Out Delta",
  "description": "Records a change in the count of users who have opted out, which may trigger amendment of an existing scope clause.",
  "type": "object",
  "required": ["dataset_id", "added_count", "as_of"],
  "properties": {
    "dataset_id": { "type": "string", "minLength": 1 },
    "added_count": { "type": "integer", "minimum": 1 },
    "removed_count": { "type": "integer", "minimum": 0 },
    "as_of": { "type": "string", "format": "date-time" },
    "source": {
      "type": "string",
      "description": "Where the opt-out signal came from (e.g. publisher preference center)."
    }
  },
  "additionalProperties": false
}
