{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mesa.dev/schemas/commitments/datasharing/usage_restriction.schema.json",
  "title": "Usage Restriction",
  "description": "Limits on how the licensee may use the licensed data.",
  "type": "object",
  "required": ["allowed_uses"],
  "properties": {
    "allowed_uses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["model_training", "evaluation", "fine_tuning", "research_only"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "redistribution": { "type": "boolean" },
    "derivative_works": { "type": "boolean" },
    "retention_days": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
