{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mesa.dev/schemas/commitments/core/participant_joined.schema.json",
  "title": "Participant Joined",
  "description": "Records a principal entering the deliberation with a declared role.",
  "type": "object",
  "required": ["principal", "role"],
  "properties": {
    "principal": {
      "type": "string",
      "description": "Principal id of the joining party."
    },
    "role": {
      "type": "string",
      "enum": ["lab", "publisher", "reviewer", "observer"]
    }
  },
  "additionalProperties": false
}
