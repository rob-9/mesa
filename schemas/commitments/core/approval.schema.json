{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mesa.dev/schemas/commitments/core/approval.schema.json",
  "title": "Approval",
  "description": "Records a party approving a commitment. Multi-party deliberations may require approvals from several principals before signoff.",
  "type": "object",
  "required": ["approves"],
  "properties": {
    "approves": {
      "type": "string",
      "description": "Commitment id being approved."
    },
    "note": { "type": "string", "maxLength": 1000 }
  },
  "additionalProperties": false
}
